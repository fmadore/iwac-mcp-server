# IWAC MCP Server Configuration
# All settings use the IWAC_ prefix. Defaults work out of the box.

# Dataset configuration
# IWAC_DATASET_NAME=fmadore/islam-west-africa-collection
# IWAC_CACHE_DIR=.cache

# Loading options
# IWAC_LAZY_LOAD_SUBSETS=true
# IWAC_PRELOAD_ARTICLES=true
# IWAC_LOAD_EMBEDDINGS=false
# IWAC_SEMANTIC_SEARCH_ENABLED=false

# Semantic search (requires: pip install iwac-mcp-server[semantic])
# Uses Gemini embeddings of full article text (embedding_OCR column).
# Queries are encoded via the Gemini API at search time.
# IWAC_EMBEDDING_MODEL=gemini-embedding-2-preview
# IWAC_EMBEDDING_DIMENSIONALITY=768

# Google API key for Gemini query embeddings (required for semantic search).
# Falls back to GOOGLE_API_KEY or GEMINI_API_KEY if IWAC_GOOGLE_API_KEY is not set.
# IWAC_GOOGLE_API_KEY=your-google-api-key-here
