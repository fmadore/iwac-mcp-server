{
  "name": "iwac-mcp-server-bundle",
  "version": "0.6.1",
  "description": "Node MCP server for the Islam West Africa Collection, packaged as a Claude Desktop extension (.mcpb).",
  "private": true,
  "type": "module",
  "main": "server/index.js",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "node scripts/bundle.mjs",
    "clean": "rimraf server",
    "prepack-mcpb": "npm run clean && npm run typecheck && npm run build",
    "pack-mcpb": "mcpb pack . iwac-mcp-server.mcpb",
    "pack-skill": "git -C .. archive --format=zip --prefix=iwac-mcp/ -o iwac-mcp-skill.zip HEAD:.claude/skills/iwac-mcp"
  },
  "dependencies": {
    "@duckdb/node-api": "^1.5.3-r.2",
    "@google/genai": "^1.50.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "optionalDependencies": {
    "@duckdb/node-bindings-darwin-arm64": "^1.5.3-r.2",
    "@duckdb/node-bindings-darwin-x64": "^1.5.3-r.2",
    "@duckdb/node-bindings-linux-arm64": "^1.5.3-r.2",
    "@duckdb/node-bindings-linux-x64": "^1.5.3-r.2",
    "@duckdb/node-bindings-win32-arm64": "^1.5.3-r.2",
    "@duckdb/node-bindings-win32-x64": "^1.5.3-r.2"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "esbuild": "^0.28.0",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3"
  }
}
