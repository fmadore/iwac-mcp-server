{
  "$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",
  "vcs": { "enabled": false, "clientKind": "git", "useIgnoreFile": false },
  "files": {
    "includes": ["src/**", "scripts/**", "test/**", "smoke-test.mjs"]
  },
  "formatter": {
    "enabled": false
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "style": {
        "noParameterAssign": "off"
      },
      "suspicious": {
        "noConsole": "off"
      }
    }
  },
  "assist": { "enabled": false }
}
